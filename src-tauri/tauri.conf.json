{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/v2/packages/tauri-schema/schema.json",
  "productName": "Tenso",
  "version": "0.1.0",
  "identifier": "com.tenso.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tenso",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "tenso"
        ]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/PatchPerson/Tenso/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc5OTg1MEE1NDIxMzE1RjUKUldUMUZSTkNwVkNZZWZ0UTlwZjUweVNVMjBMdU81OWp3RFRta0JQLzVYUEdXaWZpUEozdUxKNkkK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
